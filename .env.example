# =============================================================================
# AthenaChat — Environment Variables
# This single .env file is shared by both the Django backend and the rag/
# pipeline. Copy this file to .env and fill in real values.
# =============================================================================

# --- Django Core ---
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# --- PostgreSQL ---
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# --- CORS ---
# Comma-separated list, include scheme (http:// or https://)
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5000

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Groq (LLM Inference) ---
GROQ_API_KEY=