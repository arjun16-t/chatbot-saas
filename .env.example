# =============================================================================
# AthenaChat — Environment Variables
# This single .env file is shared by both the Django backend and the rag/
# pipeline. Copy this file to .env and fill in real values.
# =============================================================================

# --- Django Core ---
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# --- PostgreSQL ---
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# --- CORS ---
# Comma-separated list, include scheme (http:// or https://)
CORS_ALLOWED_ORIGINS=

# --- Qdrant ---
QDRANT_URL=
QDRANT_API_KEY=

# --- Groq (LLM Inference) ---
GROQ_API_KEY=

# --- Models Used ---
QUERYING_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=jinaai/jina-embeddings-v5-text-nano
SPARSE_MODEL=Qdrant/bm42-all-minilm-l6-v2-attentions

REDIS_CACHE_URL=

REDIS_CELERY_URL=